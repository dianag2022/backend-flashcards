{
  "name": "backend-flashcard",
  "version": "1.0.0",
  "description": "REST API backend for the Psychology Flashcards digital ecosystem",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "set-admin-role": "tsx src/scripts/setAdminRole.ts"
